{
  "name": "railji-business",
  "version": "1.0.0",
  "description": "Railji Business Backend - Exams and Papers Management",
  "author": "Dikamjit Borah",
  "private": true,
  "license": "MIT",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build railji-business",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start railji-business",
    "start:dev": "nest start railji-business --watch",
    "start:debug": "nest start railji-business --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/passport": "^10.0.3",
    "@supabase/supabase-js": "^2.39.0",
    "jwks-rsa": "^3.1.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "razorpay": "^2.9.6"
  },
  "devDependencies": {
    "@types/passport-jwt": "^4.0.1"
  }
}
